<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Active තියෙන එක විතරක් ටිකක් දිගටි බාර් එකක් -->
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="#00796B" /> <!-- Teal -->
            <corners android:radius="0.05dp" />
            <size android:width="0.05dp" android:height="0.05dp" />
        </shape>
    </item>

    <!-- Inactive ඒවා පොඩි රවුම් ඩොට් (Dots) වගේ -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#CCCCCC" /> <!-- Light Gray -->
            <size android:width="0.05dp" android:height="0.05dp" />
        </shape>
    </item>
</selector>
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1B6B61">

    <!-- 1. Top Bar එක (මෙහි දෝෂ නිවැරදි කර ඇත) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/topBarCard"
        android:layout_width="match_parent"
        android:layout_height="75dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#F5F5F5"
        app:layout_constraintTop_toTopOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="16dp">

            <!-- Top bar එකේ ඇති කුඩා අයිකනය -->
            <ImageView
                android:id="@+id/ivTopBarAvatar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_robot_welcome" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="12dp"
                android:layout_toEndOf="@id/ivTopBarAvatar"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MindMate"
                    android:textColor="#212121"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTopBarAvatarName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gizmo"
                    android:textColor="#616161"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Active"
                    android:textColor="#007A7A"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </RelativeLayout>
    </androidx.cardview.widget.CardView>

    <!-- 2. ඔබ රවුම් කර පෙන්වූ ගතික Lottie Animation එක සහ Gradient පසුබිම -->
    <!-- මෙය පැරණි ivCenterGizmo තිබූ ස්ථානයට ආදේශ කර ඇත -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/avatarBackgroundContainer"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        app:layout_constraintTop_toBottomOf="@id/topBarCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/lottieRobotAvatar"
            android:layout_width="200dp"
            android:layout_height="200dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.497"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.0"
            app:lottie_loop="true" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 3. Chat Messages (මෙය රොබෝවාට පහළින් ආරම්භ වන ලෙස සකසා ඇත) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChatMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="16dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/avatarBackgroundContainer"
        app:layout_constraintBottom_toTopOf="@id/layoutInputBar"/>

    <!-- 4. Message Input Field -->
    <LinearLayout
        android:id="@+id/layoutInputBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_chat_input"
            android:paddingHorizontal="16dp">

            <EditText
                android:id="@+id/etMessageInput"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_toStartOf="@id/btnSendMessage"
                android:background="@android:color/transparent"
                android:hint="Type a message..."
                android:textColor="#212121"
                android:textColorHint="#757575"
                android:textSize="15sp"
                android:importantForAutofill="no"
                android:inputType="textShortMessage"/>

            <ImageView
                android:id="@+id/btnSendMessage"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@android:drawable/ic_menu_send"
                android:contentDescription="Send"
                app:tint="#424242" />
        </RelativeLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
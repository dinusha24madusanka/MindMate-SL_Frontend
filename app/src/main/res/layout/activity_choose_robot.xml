<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E0E0E0">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:text="Choose Your\nMindMate Avatar"
        android:textAlignment="center"
        android:textColor="#004D40"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Avatar පෙන්වන ViewPager එක -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPagerAvatars"
        android:layout_width="match_parent"
        android:layout_height="350dp"
        app:layout_constraintBottom_toTopOf="@+id/dotsIndicator"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        android:layout_marginTop="20dp"/>

    <!-- Slide Bar / Dots Indicator එක -->
    <!-- රූපයේ පරිදිම විශාල නිල් තිතක් සහ කුඩා අළු තිත් පෙන්වන Indicator එක -->
    <com.tbuonomo.viewpagerdotsindicator.DotsIndicator
        android:id="@+id/dotsIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        app:dotsColor="#E0E0E0"
        app:dotsCornerRadius="8dp"
        app:dotsSize="10dp"
        app:dotsSpacing="6dp"
        app:dotsWidthFactor="1.0"
        app:selectedDotColor="#00796B"
        app:progressMode="false"
        app:layout_constraintBottom_toTopOf="@+id/btnConfirmSelection"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnConfirmSelection"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginHorizontal="36dp"
        android:layout_marginBottom="80dp"
        android:background="@drawable/btn_rounded_teal"
        android:text="Start Chatting"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
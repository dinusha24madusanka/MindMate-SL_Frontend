<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#D9D9D9"> <TextView
    android:id="@+id/tvChooseTitle"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Choose Your\nMindMate"
    android:textColor="#007A7A"
    android:textSize="28sp"
    android:textStyle="bold"
    android:gravity="center"
    android:layout_marginTop="60dp"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent" />

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottieRobot"
        android:layout_width="220dp"
        android:layout_height="220dp"
        app:lottie_rawRes="@raw/robot_idle"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        app:layout_constraintTop_toBottomOf="@+id/tvChooseTitle"
        app:layout_constraintBottom_toTopOf="@+id/tvRobotName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.4" />

    <TextView
        android:id="@+id/tvRobotName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gizmo"
        android:textColor="#007A7A"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@+id/llIndicators"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/llIndicators"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="40dp"
        app:layout_constraintBottom_toTopOf="@+id/btnStartChatting"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:layout_width="24dp"
            android:layout_height="6dp"
            android:background="#007A7A"
            android:layout_marginEnd="6dp"/>

        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="#4A2E2B"
            android:backgroundTint="#4A2E2B"/>
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStartChatting"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Start Chatting"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textAllCaps="false"
        app:backgroundTint="#007A7A"
        app:cornerRadius="28dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>